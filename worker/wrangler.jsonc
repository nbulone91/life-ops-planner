{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "life-ops-planner-api",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-27",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "kv_namespaces": [
    {
      "binding": "PLANNER_KV",
      "id": "replace-with-kv-namespace-id"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://nbulone91.github.io",
    "OPENAI_MODEL": "gpt-5"
  }
}
